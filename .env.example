# URL of the CruxAI API
NEXT_PUBLIC_API_URL=http://localhost:4000

# Google reCAPTCHA v3 site key (leave blank to disable captcha in dev)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Public site URL (used for SEO canonical, OpenGraph, sitemap, robots)
NEXT_PUBLIC_SITE_URL=https://cruxai.az

# Analytics (optional — leave blank to disable)
NEXT_PUBLIC_YANDEX_METRICA_ID=
NEXT_PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=

# Demo / how-to video. Direct .mp4 URL or a YouTube link.
# Leave blank to use the bundled /public/demo.mp4.
NEXT_PUBLIC_DEMO_VIDEO_URL=

# "GitHub" link in the header → the source repo
NEXT_PUBLIC_GITHUB_URL=https://github.com/tamerlanmusayev/cruxai-frontend

# Google OAuth web Client ID (same project as API GOOGLE_CLIENT_ID)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Telegram login bot username (without @)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
